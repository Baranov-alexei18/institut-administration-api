{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",

    "target": "ES2020",

    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "sourceMap": true,
    "outDir": "./dist",

    "baseUrl": "./",

    "incremental": true,
    "skipLibCheck": true,

    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,

    "noImplicitAny": false
  },
  "include": ["src/**/*"]
}
